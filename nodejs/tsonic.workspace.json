{
  "$schema": "https://tsonic.org/schema/workspace/v1.json",
  "surface": "@tsonic/js",
  "dotnetVersion": "net10.0",
  "dotnet": {
    "typeRoots": [
      "node_modules/@tsonic/nodejs"
    ],
    "libraries": [
      "libs/Tsonic.JSRuntime.dll",
      "libs/nodejs.dll"
    ],
    "frameworkReferences": [
      {
        "id": "Microsoft.AspNetCore.App",
        "types": "@tsonic/aspnetcore"
      }
    ],
    "packageReferences": [
      {
        "id": "Tsonic.JSRuntime",
        "version": "0.0.4",
        "types": "@tsonic/js"
      },
      {
        "id": "Tsonic.Nodejs",
        "version": "1.0.1",
        "types": "@tsonic/nodejs"
      }
    ]
  }
}
